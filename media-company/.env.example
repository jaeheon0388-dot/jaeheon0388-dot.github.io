# ==== LLM (OpenRouter) ====
# https://openrouter.ai/keys 에서 발급
OPENROUTER_API_KEY=
# 용도별 모델 라우팅 (예: anthropic/claude-sonnet-4.5, google/gemini-2.5-flash 등)
MODEL_WRITING=
MODEL_ANALYSIS=
MODEL_CLASSIFY=

# ==== Telegram ====
# @BotFather 로 봇 생성 후 토큰 발급, 챗 ID는 봇에게 아무 메시지 보낸 뒤
# https://api.telegram.org/bot<토큰>/getUpdates 에서 확인
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ==== Instagram (Meta Graph API) — 계정별 완전 분리 ====
# Meta Business Suite → 앱 → instagram_content_publish 권한 포함 장기 토큰
IG_BEAUTY_ACCESS_TOKEN=
IG_BEAUTY_ACCOUNT_ID=
IG_HUMOR_ACCESS_TOKEN=
IG_HUMOR_ACCOUNT_ID=

# Graph API는 공개 URL의 이미지만 발행 가능 → output/ 폴더를 서빙하는 공개 베이스 URL
# (예: GitHub Pages, S3, 혹은 임시로 https://transfer.sh 등. HANDOFF.md 참고)
PUBLIC_MEDIA_BASE_URL=

# ==== YouTube Data API ====
# Google Cloud Console에서 OAuth 클라이언트(데스크톱) JSON 다운로드 경로
YT_CLIENT_SECRET_PATH=
# 최초 인증 후 자동 생성/갱신되는 토큰 저장 경로 (예: news_shorts/yt_token.json)
YT_TOKEN_PATH=

# ==== 기타 ====
# 한글 폰트 (예: /usr/share/fonts/truetype/nanum/NanumGothicBold.ttf)
FONT_PATH=
